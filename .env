# Local environment values. .env is gitignored (CFG-9.4).
# These are LOCAL, non-production values only. Real secrets never live in git.

# --- MongoDB (CFG-9.5) ---
# Root/admin user — bootstrap only; not used by the application services.
MONGO_ROOT_USERNAME=configroot
MONGO_ROOT_PASSWORD=local-dev-root-password

# Read-write user — used by the Admin API (config-api).
MONGO_APP_RW_USERNAME=config_api
MONGO_APP_RW_PASSWORD=local-dev-rw-password

# Read-only user — used by the library (service-a / service-b). Least privilege.
MONGO_APP_RO_USERNAME=config_reader
MONGO_APP_RO_PASSWORD=local-dev-ro-password

# --- Redis (CFG-9.5) ---
REDIS_PASSWORD=local-dev-redis-password

# --- Admin API ---
# Fail-closed admin key, sent in the 'X-Api-Key' header. config-ui reads this automatically
# (baked into its build via VITE_ADMIN_API_KEY) — no manual entry in the UI.
ADMIN_API_KEY=local-dev-admin-key

# --- Host ports (only the application services are published to the host) ---
CONFIG_API_PORT=8080
CONFIG_UI_PORT=8081
